{
  "name": "@peterseibel/bells",
  "version": "0.8.1",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gigamonkey/bells",
    "directory": "libs/ts"
  },
  "scripts": {
    "build": "tsc && node scripts/finish-build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "tsc --noEmit && node --import tsx --test test/*.test.ts",
    "golden:generate": "node --import tsx scripts/generate-golden.ts",
    "prepare": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./calendars": {
      "types": "./dist/calendars.d.ts",
      "default": "./dist/calendars.js"
    },
    "./validate": {
      "types": "./dist/validate.d.ts",
      "default": "./dist/validate.js"
    }
  },
  "bin": {
    "bells-validate": "dist/bin/validate.js"
  },
  "files": [
    "dist/",
    "src/",
    "README.md"
  ],
  "peerDependencies": {
    "@js-temporal/polyfill": ">=0.4"
  },
  "devDependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "@types/node": "^25.9.2",
    "temporal-polyfill": "^0.3.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
