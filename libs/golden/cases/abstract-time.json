    { "id": "warnings-period-on-holiday", "method": "timeWarnings", "args": { "bound": { "date": "2025-10-13", "anchor": "start_of_period", "offset": "+00:00" } } },
    { "id": "warnings-period-no-numbered", "method": "timeWarnings", "args": { "bound": { "date": "2026-01-09", "anchor": "start_of_period", "offset": "+00:00" } } },
