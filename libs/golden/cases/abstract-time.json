{
  "description": "The abstract-time API (resolveDay, addSchoolDays, resolveTime, periodOnDate, currentOrNextPeriodNumber, timeWarnings, and parse/format round-tripping) on a synthetic year with a Monday holiday (2025-10-13), a Thanksgiving Thu-Fri pair, a full vacation week (2026-02-16..20), a SHORT day missing period 3, an ASSEMBLY day with no numbered periods, and a DST fall-back (2025-11-02). Some queries carry structured args: resolveDay/timeWarnings/resolveTime take a 'day' or 'bound' object; resolveTime takes an optional 'period'. timeWarnings is serialized to its warning count (message text is not part of the compatibility contract). canonicalizeTime runs formatTime(parseTime(spec)).",
  "calendars": ["abstract-time.json"],
  "options": {},
  "queries": [
    { "id": "resolve-day-omitted", "method": "resolveDay", "args": { "base": "2025-10-06" } },
    { "id": "resolve-day-absolute", "method": "resolveDay", "args": { "base": "2025-10-06", "day": { "type": "date", "date": "2025-10-13" } } },
    { "id": "resolve-day-school-plus1", "method": "resolveDay", "args": { "base": "2025-10-10", "day": { "type": "schoolDays", "n": 1 } } },
    { "id": "resolve-day-school-minus1", "method": "resolveDay", "args": { "base": "2025-10-14", "day": { "type": "schoolDays", "n": -1 } } },
    { "id": "resolve-day-school-plus3", "method": "resolveDay", "args": { "base": "2025-10-10", "day": { "type": "schoolDays", "n": 3 } } },
